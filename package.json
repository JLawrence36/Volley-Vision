{
  "name": "volleyvision",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor@latest",
    "eas:configure": "npx eas-cli@latest build:configure",
    "build:android:preview": "npx eas-cli@latest build --platform android --profile preview",
    "build:ios:preview": "npx eas-cli@latest build --platform ios --profile preview",
    "build:all:production": "npx eas-cli@latest build --platform all --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^56.0.0",
    "expo-document-picker": "~56.0.4",
    "expo-video": "~56.1.3",
    "react": "19.2.3",
    "react-native": "0.85.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=22.13.0"
  }
}
